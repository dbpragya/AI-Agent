{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/server/server.js"
    },
    {
      "src": "/(.*)\\.(ico|png|svg|jpg|jpeg|css|js|woff|woff2|ttf|eot|mp4|webm)$",
      "dest": "/client/$1.$2"
    },
    {
      "src": "/(.*)",
      "dest": "/client/index.html"
    }
  ]
}
